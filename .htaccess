# MiSuite Plataforma Unificada
# ——— Cache Control ———
<FilesMatch "\.(html|htm)$">
    <ifModule mod_headers.c>
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </ifModule>
</FilesMatch>

# ——— Reescritura de rutas ———
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Servir assets estáticos (JS/CSS) tal cual (Vite los genera con hash únicos)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. MPA Routing: Mapear subcarpetas a sus respectivos index.html
  RewriteRule ^admin(/.*)?$ admin/index.html [L]
  RewriteRule ^card(/.*)?$ card/index.html [L]
  RewriteRule ^turnos(/.*)?$ turnos/index.html [L]

  # 3. Raíz: Landing
  RewriteRule ^$ index.html [L]
</IfModule>
