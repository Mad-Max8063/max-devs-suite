# MiSuite Plataforma Unificada v1.0.8 - Cache Bust v6
# --- BLOQUEO DE SCRIPTS ZOMBIE (Protección contra caché persistente) ---
# Solo bloqueamos archivos legacy en raíz o carpetas de módulo. 
# Los archivos en /assets/ (empaquetados por Vite) están permitidos.
<IfModule mod_rewrite.c>
  RewriteRule ^(app|card|engine|supabase|utils)\.js$ - [F,L]
  RewriteRule ^(admin|card|turnos)/(app|card|engine|supabase|utils)\.js$ - [F,L]
</IfModule>

# ——— Cache Control (Anti-HCDN) ———
<FilesMatch "\.(html|htm|js|css|json|webmanifest)$">
    FileETag None
    <ifModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </ifModule>
</FilesMatch>

# ——— CORS Assets (Para Subdominios) ———
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|json|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|ico)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ——— Reescritura de rutas ———
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force no-cache for HTML files to prevent stale dashboard loads
  <FilesMatch "\.(html|htm)$">
    FileETag None
    <ifModule mod_headers.c>
       Header unset ETag
       Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
       Header set Pragma "no-cache"
       Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </ifModule>
  </FilesMatch>

  # A. Excepción para Assets: Si existe el archivo físicamente, servirlo y parar.
  # Esto cubre /assets/..., /admin/assets/..., /card/assets/..., /turnos/assets/...
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Excepción atómica para carpetas de assets y archivos estáticos clave
  RewriteRule ^(assets|admin/assets|card/assets|turnos/assets)/.*$ - [L]
  RewriteRule ^.*\.(json|webmanifest|ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|sw-v6\.js)$ - [L]

  # B. Subdomain Routing: admin.suito.pro
  RewriteCond %{HTTP_HOST} ^admin\.suito\.pro$ [NC]
  RewriteRule ^(.*)$ admin/dashboard-v2028.html [L]

  # C. MPA Routing (vía subcarpetas en dominio principal)
  RewriteRule ^admin(/.*)?$ admin/dashboard-v2028.html [L]
  
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^card(/.*)?$ card/index.html [L]
  
  RewriteRule ^turnos(/.*)?$ turnos/index.html [L]

  # D. Raíz: Landing
  RewriteRule ^$ home-v2028.html [L]
</IfModule>
