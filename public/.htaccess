# MiSuite Plataforma Unificada v1.0.8 - Cache Bust v6
# ——— Cache Control (Anti-HCDN) ———
<FilesMatch "\.(html|htm|js|css|json|webmanifest)$">
    FileETag None
    <ifModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </ifModule>
</FilesMatch>

# ——— CORS Assets (Para Subdominios) ———
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|json|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|ico)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ——— Reescritura de rutas ———
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # A. Excepción para Assets: Si existe el archivo físicamente, servirlo y parar.
  # Esto cubre /assets/..., /admin/assets/..., /card/assets/..., /turnos/assets/...
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Excepción atómica para carpetas de assets y archivos estáticos clave
  RewriteRule ^(assets|admin/assets|card/assets|turnos/assets)/.*$ - [L]
  RewriteRule ^.*\.(json|webmanifest|ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|sw-v6\.js)$ - [L]

  # B. Soporte para Subdominios (cuando el host es admin.suito.pro, etc.)
  # Nota: Hostinger suele mapear el subdominio a la carpeta, pero esta regla asegura el routing interno.
  RewriteCond %{HTTP_HOST} ^admin\.suito\.pro$ [NC]
  RewriteRule ^$ admin/index.html [L]

  RewriteCond %{HTTP_HOST} ^card\.suito\.pro$ [NC]
  RewriteRule ^$ card/index.html [L]

  RewriteCond %{HTTP_HOST} ^turnos\.suito\.pro$ [NC]
  RewriteRule ^$ turnos/index.html [L]

  # C. MPA Routing (vía subcarpetas en dominio principal)
  RewriteRule ^admin(/.*)?$ admin/index.html [L]
  RewriteRule ^card(/.*)?$ card/index.html [L]
  RewriteRule ^turnos(/.*)?$ turnos/index.html [L]

  # D. Raíz: Landing
  RewriteRule ^$ index.html [L]
</IfModule>
