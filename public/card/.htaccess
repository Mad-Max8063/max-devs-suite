<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /card/

  # Si la petición es un archivo real, directorio o enlace simbólico, servirlo directamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d [OR]
  RewriteCond %{REQUEST_FILENAME} -l
  RewriteRule . - [L]

  # Exclusión explícita para evitar que archivos estáticos faltantes devuelvan el HTML de la SPA
  # Esto ayuda a diagnosticar 404 reales y evita errores 422 en CDN/Optimizadores
  RewriteCond %{REQUEST_URI} \.(manifest|json|png|jpg|jpeg|svg|css|js|webp|ico|webmanifest)$ [NC]
  RewriteRule . - [R=404,L]

  # Redirección SPA: Todo lo demás va a index.html
  RewriteRule . /card/index.html [L]
</IfModule>
