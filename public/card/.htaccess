<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /card/

  # Si la petición es un archivo real, directorio o enlace simbólico, servirlo directamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d [OR]
  RewriteCond %{REQUEST_FILENAME} -l
  RewriteRule . - [L]

  # Exclusión explícita para evitar que archivos estáticos faltantes devuelvan el HTML de la SPA
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} \.(manifest|json|png|jpg|jpeg|svg|css|js|webp|ico|webmanifest)$ [NC]
  RewriteRule . - [R=404,L]

  # Forzar no-caché para el manifest
  <FilesMatch "manifest-v4\.webmanifest$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>

  # Forzar no-caché para el Service Worker (el navegador gestiona su propio ciclo de vida)
  <Files "sw-v4.js">
    <IfModule mod_headers.c>
      Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
      Header set Pragma "no-cache"
      Header set Expires 0
    </IfModule>
  </Files>

  # Redirección SPA: Todo lo demás va a index.html
  # Excluir el Service Worker de la redirección (aunque ya es archivo real, exclusión explícita)
  RewriteCond %{REQUEST_URI} !^/card/sw-v4\.js$
  RewriteRule . /card/index.html [L]
</IfModule>
