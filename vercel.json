{
  "framework": "vite",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "suito.pro"
        }
      ],
      "destination": "https://www.suito.pro/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/card/((?!css/|js/|assets/|.*\\.).*)", "destination": "/card/index.html" },
    { "source": "/edit/((?!.*\\.).*)", "destination": "/card/index.html" },
    { "source": "/turnos/((?!.*\\.).*)", "destination": "/turnos/index.html" },
    { "source": "/((?!assets/|api/|images/|.*\\.).*)", "destination": "/index.html" }
  ]
}
