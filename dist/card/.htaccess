<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /card/

  # ─────────────────────────────────────────────────────────────
  # 1) SEO BOT INTERCEPTOR — debe ir ANTES del fallback SPA.
  #    Solo rutea al PHP cuando:
  #      a) el UA es un scraper social conocido
  #      b) la URL es /card/<slug> (un único segmento, sin extensión)
  #    Los humanos nunca entran aquí.
  # ─────────────────────────────────────────────────────────────
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|TelegramBot|WhatsApp|Discordbot|Pinterest|vkShare|redditbot|Applebot|Googlebot|bingbot|DuckDuckBot|YandexBot|Embedly|SkypeUriPreview|iframely) [NC]
  RewriteCond %{REQUEST_URI} ^/card/([a-z0-9][a-z0-9-]{0,62}[a-z0-9])/?$
  RewriteRule ^([a-z0-9][a-z0-9-]{0,62}[a-z0-9])/?$ /card/card_seo_proxy.php?slug=$1 [L,QSA]

  # ─────────────────────────────────────────────────────────────
  # 2) Archivos reales (assets compilados por Vite): servirlos directo.
  # ─────────────────────────────────────────────────────────────
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d [OR]
  RewriteCond %{REQUEST_FILENAME} -l
  RewriteRule . - [L]

  # ─────────────────────────────────────────────────────────────
  # 3) Activos estáticos faltantes → 404 real (evitar que Apache
  #    devuelva el HTML de la SPA por un .js/.css inexistente).
  # ─────────────────────────────────────────────────────────────
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} \.(manifest|json|png|jpg|jpeg|svg|css|js|webp|ico|webmanifest|php)$ [NC]
  RewriteRule . - [R=404,L]

  # ─────────────────────────────────────────────────────────────
  # 4) Cache headers del manifest y service worker
  # ─────────────────────────────────────────────────────────────
  <FilesMatch "manifest-v2029\.webmanifest$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>

  <Files "sw-v2029.js">
    <IfModule mod_headers.c>
      Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
      Header set Pragma "no-cache"
      Header set Expires 0
    </IfModule>
  </Files>

  # ─────────────────────────────────────────────────────────────
  # 5) SPA fallback: cualquier otra URL → index.html (humanos).
  # ─────────────────────────────────────────────────────────────
  RewriteCond %{REQUEST_URI} !^/card/sw-v2029\.js$
  RewriteCond %{REQUEST_URI} !^/card/card_seo_proxy\.php$
  RewriteRule . /card/index.html [L]
</IfModule>
